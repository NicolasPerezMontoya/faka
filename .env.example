# ============================================================
# faka — Dashboard Omnicanal de Ventas + Capa de IA
# Root env example. Copy to .env (gitignored) and fill values.
# Each app/package may have its own .env.example with locals.
# ============================================================

# -------- Supabase (set per environment) --------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# NEVER prefix the next one with NEXT_PUBLIC_* — service-role key
# is server-side only. The CI lint enforces this (eslint rule).
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# -------- Orchestrator (Railway) ----------------------------
PORT=4000
LOG_LEVEL=info

# -------- Initial Super Admin (seeder) ----------------------
# Used once by `pnpm db:reset` seeder; rotate after first login.
INITIAL_SUPER_ADMIN_EMAIL=nicolasperezmontoya@gmail.com
INITIAL_SUPER_ADMIN_PASSWORD=

# -------- LLM providers (Phase 5) ---------------------------
# See scripts/discovery/.env.example for provider details and
# auto-detection order. The dashboard + orchestrator will share
# the same resolution logic.
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MOONSHOT_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

# -------- Channel credentials (filled in respective phases) -
# WordPress (Phase 2)
# Not yet delivered by client. The WordPress connector degrades to
# healthCheck { ok:false, last_error:"not configured" }, fetchOrders
# returns [], and the orchestrator webhook route returns 503 with a
# "not_configured" JSON payload when any of these are unset.
WORDPRESS_API_URL=
WORDPRESS_API_KEY=
WORDPRESS_API_SECRET=
WORDPRESS_WEBHOOK_SECRET=

# -------- Matching cascade (Phase 2) ------------------------
# Thresholds applied per cascade level. Items scoring below
# MATCH_QUEUE_CUTOFF land in the human validation queue.
MATCH_EMBED_HIGH=0.92
MATCH_EMBED_MID=0.78
MATCH_ARBITER=0.80
MATCH_QUEUE_CUTOFF=0.78
# Daily token cap on the LLM arbiter (cost guardrail).
LLM_DAILY_TOKEN_CAP=200000
# OpenAI embeddings (text-embedding-3-small @ 1536 dims).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Mercado Libre (Phase 2.1) — OAuth + webhook.
# Graceful degrade when any of these are unset: healthCheck returns
# ok:false + last_error:"not configured", fetchOrders/fetchProducts
# return [], POST /webhooks/mercadolibre returns 503 with not_configured
# JSON, and the three Railway crons exit 0 (NOT 1, to silence pager
# noise pre-OAuth) after writing connector_runs.status="failed",
# errors_json={reason:"not_configured"}. Cliente registers app at
# https://developers.mercadolibre.com.co before live OAuth.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# OAuth callback URL — prod: https://orchestrator.fakawholesale.com/oauth/mercadolibre/callback
# dev: http://localhost:8080/oauth/mercadolibre/callback
ML_REDIRECT_URI=
# Shared secret for ML webhook signed-query-params HMAC-SHA256 verify
# (RESEARCH §Pattern 3 — same value as ML_CLIENT_SECRET per ML docs).
ML_WEBHOOK_SECRET=
# Site ID hardcoded to Colombia. F2.1 ships single-site; multi-site
# is an explicit non-goal (PATTERNS §"F2.1-NEW — Single ML site hardcoded").
ML_SITE_ID=MCO

# Dropi (Phase 4) — panel access
DROPI_USER=
DROPI_PASS=

# POS (Phase 3) — webhook signing secret
POS_WEBHOOK_SECRET=

# WhatsApp Business Cloud API (Phase 5.5) — Meta
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_WEBHOOK_VERIFY_TOKEN=

# -------- Misc ---------------------------------------------
# Max bytes for CSV upload (default 20MB; see RESEARCH §6)
CSV_MAX_BYTES=20971520
