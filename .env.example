# ============================================================
# faka — Dashboard Omnicanal de Ventas + Capa de IA
# Root env example. Copy to .env (gitignored) and fill values.
# Each app/package may have its own .env.example with locals.
# ============================================================

# -------- Supabase (set per environment) --------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# NEVER prefix the next one with NEXT_PUBLIC_* — service-role key
# is server-side only. The CI lint enforces this (eslint rule).
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# -------- Orchestrator (Railway) ----------------------------
PORT=4000
LOG_LEVEL=info

# -------- Initial Super Admin (seeder) ----------------------
# Used once by `pnpm db:reset` seeder; rotate after first login.
INITIAL_SUPER_ADMIN_EMAIL=nicolasperezmontoya@gmail.com
INITIAL_SUPER_ADMIN_PASSWORD=

# -------- LLM providers (Phase 5) ---------------------------
# See scripts/discovery/.env.example for provider details and
# auto-detection order. The dashboard + orchestrator will share
# the same resolution logic.
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MOONSHOT_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

# -------- Channel credentials (filled in respective phases) -
# WordPress (Phase 2)
WORDPRESS_API_URL=
WORDPRESS_API_KEY=

# Mercado Libre (Phase 4) — developer app credentials
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Dropi (Phase 4) — panel access
DROPI_USER=
DROPI_PASS=

# POS (Phase 3) — webhook signing secret
POS_WEBHOOK_SECRET=

# WhatsApp Business Cloud API (Phase 5.5) — Meta
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_WEBHOOK_VERIFY_TOKEN=

# -------- Misc ---------------------------------------------
# Max bytes for CSV upload (default 20MB; see RESEARCH §6)
CSV_MAX_BYTES=20971520
