{
  "name": "@faka/discovery",
  "version": "0.1.0",
  "description": "Phase 0 discovery — catalog matching exploration across channels",
  "private": true,
  "type": "module",
  "scripts": {
    "match": "node --env-file-if-exists=.env --import tsx match-explorer.ts",
    "match:dry": "node --env-file-if-exists=.env --import tsx match-explorer.ts --no-llm --no-embeddings",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.7"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "ai": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
