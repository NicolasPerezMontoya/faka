# =============================================================
# Discovery match-explorer — LLM provider configuration
# =============================================================
# Copy to .env (gitignored) and fill what you need.
# The script picks a provider in this priority order:
#
#   1. CLI flag (--provider / --model) — wins always
#   2. LLM_PROVIDER + LLM_MODEL env vars
#   3. Auto-detection from whichever API key is present below
#
# If multiple keys are set without LLM_PROVIDER, auto-detection order:
#   AI_GATEWAY_API_KEY → ANTHROPIC_API_KEY → OPENAI_API_KEY →
#   GOOGLE_GENERATIVE_AI_API_KEY → MOONSHOT_API_KEY → OPENAI_COMPATIBLE_BASE_URL
# =============================================================

# -------- Default provider/model (overrides auto-detection) --------
# Recommended values:
#   LLM_PROVIDER=gateway    LLM_MODEL=anthropic/claude-haiku-4-5
#   LLM_PROVIDER=anthropic  LLM_MODEL=claude-haiku-4-5-20251001
#   LLM_PROVIDER=openai     LLM_MODEL=gpt-4o-mini
#   LLM_PROVIDER=google     LLM_MODEL=gemini-2.5-flash
#   LLM_PROVIDER=moonshot   LLM_MODEL=kimi-k2-0905-preview
#   LLM_PROVIDER=compatible LLM_MODEL=<whatever-the-endpoint-supports>
LLM_PROVIDER=
LLM_MODEL=

# -------- Vercel AI Gateway (recommended for production) -----------
# https://vercel.com/docs/ai-gateway — unified API, observability,
# automatic fallback between providers, single key.
# Model strings look like "anthropic/claude-haiku-4-5", "openai/gpt-4o".
AI_GATEWAY_API_KEY=

# -------- Anthropic (Claude) ---------------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# -------- OpenAI (GPT) ---------------------------------------------
# Get a key at https://platform.openai.com/
OPENAI_API_KEY=

# -------- Google (Gemini) ------------------------------------------
# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# -------- Moonshot (Kimi K2) ---------------------------------------
# Moonshot exposes an OpenAI-compatible API at https://api.moonshot.ai/v1
# Setting MOONSHOT_API_KEY auto-configures the compatible endpoint below.
MOONSHOT_API_KEY=

# -------- Any OpenAI-compatible provider ---------------------------
# Use this for self-hosted models, Together AI, Groq, Fireworks, etc.
# When set without MOONSHOT_API_KEY, it becomes the default for
# LLM_PROVIDER=compatible.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
# Example:
#   OPENAI_COMPATIBLE_API_KEY=sk-...
#   OPENAI_COMPATIBLE_BASE_URL=https://api.together.xyz/v1

# -------- Tuning ---------------------------------------------------
# Max LLM arbiter calls per run (cost guardrail). CLI flag overrides.
LLM_MAX_CALLS=100
