# apps/orchestrator/.env.example
# Copy to .env for local development. Railway reads these from project env vars.

PORT=8080
LOG_LEVEL=info

# Supabase (service-role only — never NEXT_PUBLIC_*)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Channel placeholders — real impls land in their target phases.
# WordPress (F2) — graceful degrade when any var below is unset.
# Read once at boot; on rotation, restart the Railway service.
WORDPRESS_API_URL=
WORDPRESS_API_KEY=
WORDPRESS_API_SECRET=
WORDPRESS_WEBHOOK_SECRET=

# F2 matching cascade thresholds (overridable per environment).
MATCH_EMBED_HIGH=0.92
MATCH_EMBED_MID=0.78
MATCH_ARBITER=0.80
MATCH_QUEUE_CUTOFF=0.78
LLM_DAILY_TOKEN_CAP=200000
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Mercado Libre (F2.1) — OAuth + webhook. Graceful degrade when any
# of these are unset: healthCheck returns ok:false, syncs no-op,
# webhook 503s. Cliente registers app at https://developers.mercadolibre.com.co
# before live OAuth. Vars are read once at boot; on rotation, restart
# the Railway service (same lifecycle as the WordPress block above).
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# OAuth callback URL — prod: https://orchestrator.fakawholesale.com/oauth/mercadolibre/callback
# dev: http://localhost:8080/oauth/mercadolibre/callback
ML_REDIRECT_URI=
# Shared secret for ML webhook signed-query-params HMAC-SHA256 verify
# (RESEARCH §Pattern 3 — same value as ML_CLIENT_SECRET per ML docs).
ML_WEBHOOK_SECRET=
# Site ID hardcoded to Colombia. F2.1 ships single-site only.
ML_SITE_ID=MCO

# Dropi (F4) — panel access (CSV-primary per discovery findings)
DROPI_USER=
DROPI_PASS=

# POS (F3) — webhook signing secret
POS_WEBHOOK_SECRET=

# WhatsApp Business Cloud API (F5.5) — Meta
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_WEBHOOK_VERIFY_TOKEN=

# Falabella (F6) — deferred / feature-flag off in F1
FALABELLA_API_KEY=
FALABELLA_ENABLED=false

# OpenAI (F2 cascade level 4 — embeddings). Required for matching
# to score the embeddings level; without it the cascade falls back
# to the LLM arbiter (level 5) directly when levels 1-3 don't match.
OPENAI_API_KEY=

# LLM providers (F2 cascade level 5 arbiter — any ONE is sufficient,
# autodetected in this order: gateway → anthropic → openai → google →
# moonshot → compatible). Adapter lives in @faka/llm.
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MOONSHOT_API_KEY=
LLM_PROVIDER=
LLM_MODEL=
