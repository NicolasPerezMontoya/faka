# apps/dashboard/.env.example
# Copy to .env.local for local dev. Vercel reads these from project env vars.
#
# CC-11 constraint (F2 PLAN §2.0.2): the dashboard NEVER reads
# WordPress, OpenAI, or LLM-provider credentials. Those live
# orchestrator-side only. Validation queue + Hoy view pull from
# role-gated DB views via the anon key + Supabase Auth; product
# comparison data flows through Server Actions, not browser-side
# WooCommerce API calls.

# Public (sent to browser — never put a service-role key here).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER prefix with NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# CSV upload max bytes (default 20MB per ADR-001 Storage bucket cap).
CSV_MAX_BYTES=20971520

# Initial Super Admin (used by packages/db seeder; not by the app at runtime).
INITIAL_SUPER_ADMIN_EMAIL=nicolasperezmontoya@gmail.com
INITIAL_SUPER_ADMIN_PASSWORD=
